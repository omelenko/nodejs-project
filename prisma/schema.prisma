datasource db {
  provider = "postgresql"
}
// --- ОСНОВНІ СУТНОСТІ ---

model User {
  id        Int         @id @default(autoincrement())
  username  String      @unique
  email     String      @unique
  password  String      // Тут зберігатимемо хеш
  playlists Playlist[]  // Плейлисти, які створив користувач
  favorites Favourite[] // Улюблені треки
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Artist {
  id           Int           @id @default(autoincrement())
  stageName    String        @unique // Псевдонім (обов'язковий і унікальний)
  firstName    String?       // Справжнє ім'я
  lastName     String?       // Справжнє прізвище
  bio          String?       @db.Text
  country      String?       // Країна походження (напр., "Ukraine")

  // Візуальні елементи
  avatarUrl    String?
  bannerUrl    String?
  isVerified   Boolean       @default(false)


  // Зв'язки
  albums       ArtistAlbum[]
  tracks       ArtistTrack[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Album {
  id          Int           @id @default(autoincrement())
  title       String
  coverUrl    String?
  releaseYear Int?
  // Зв'язок з проміжною таблицею
  artists     ArtistAlbum[]
  tracks      Track[]
}

model ArtistAlbum {
  artistId Int
  albumId  Int
  artist   Artist @relation(fields: [artistId], references: [id])
  album    Album  @relation(fields: [albumId], references: [id])

  @@id([artistId, albumId]) // Спільний ключ
}


model Track {
  id        Int             @id @default(autoincrement())
  title     String
  genre     String?
  duration  Int
  fileUrl   String
  albumId   Int?
  album     Album?          @relation(fields: [albumId], references: [id])
  artists   ArtistTrack[]   // Зв'язок із виконавцями (фіти)
  playlists PlaylistTrack[]
  favorited Favourite[]
}

model ArtistTrack {
  artistId Int
  trackId  Int
  artist   Artist @relation(fields: [artistId], references: [id])
  track    Track  @relation(fields: [trackId], references: [id])

  @@id([artistId, trackId]) // Композитний ключ
}

model Playlist {
  id        Int             @id @default(autoincrement())
  name      String
  creatorId Int
  creator   User            @relation(fields: [creatorId], references: [id])
  tracks    PlaylistTrack[]
  createdAt DateTime        @default(now())
}

// --- ПРОМІЖНІ ТАБЛИЦІ (ДЛЯ ЗВ'ЯЗКІВ БАГАТО-ДО-БАГАТЬОХ) ---

// Зв'язок: Плейлист <-> Треки
model PlaylistTrack {
  playlistId Int
  trackId    Int
  playlist   Playlist @relation(fields: [playlistId], references: [id])
  track      Track    @relation(fields: [trackId], references: [id])
  addedAt    DateTime @default(now())

  @@id([playlistId, trackId]) // Композитний первинний ключ
}

// Зв'язок: Користувач <-> Улюблені треки
model Favourite {
  id      Int      @id @default(autoincrement())
  userId  Int
  trackId Int
  user    User     @relation(fields: [userId], references: [id])
  track   Track    @relation(fields: [trackId], references: [id])
  addedAt DateTime @default(now())

  @@unique([userId, trackId]) // Користувач може додати трек в улюблені лише один раз
}